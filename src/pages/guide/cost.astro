---
import Layout from "../../layouts/Layout.astro";
import { assetPath, basePath, homePath } from "../../lib/site";

const logo = assetPath("logo.svg");

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const pageUrl = new URL(`${basePath}guide/cost/`, siteUrl).toString();
const homeUrl = new URL(homePath, siteUrl).toString();
const guideIndexUrl = new URL(`${basePath}guide/`, siteUrl).toString();

const title = "遺品整理の費用相場｜名古屋市の間取り別実勢価格と内訳の見方｜徳丸商会";
const description = "名古屋市の遺品整理費用の相場を間取り別（1K〜4LDK）に解説。料金内訳・追加料金が発生しない見積書の見方・買取相殺で費用を軽減する仕組み・1社だけで決めずに比較すべき理由まで網羅。徳丸商会の料金は1K¥30,000〜。";

const feeRows = [
  { size: "1K・1DK", scene: "単身者向けマンション", market: "30,000〜70,000円", time: "1〜3時間" },
  { size: "1LDK・2DK", scene: "夫婦/単身広め", market: "60,000〜120,000円", time: "2〜6時間" },
  { size: "2LDK・3DK", scene: "ファミリー向け", market: "100,000〜180,000円", time: "3〜8時間" },
  { size: "3LDK・4DK", scene: "戸建て/大型マンション", market: "150,000〜240,000円", time: "5〜12時間" },
  { size: "4LDK以上・戸建て", scene: "二世帯・空き家含む", market: "200,000円〜", time: "1〜2日" },
];

const breakdown = [
  { label: "基本作業費", percent: "40-50%", text: "スタッフの人件費（仕分け・梱包・搬出）。間取りと荷物量で決定" },
  { label: "車両費", percent: "10-15%", text: "2tトラック等の車両使用料。荷物量により台数が変動" },
  { label: "廃棄物処分費", percent: "20-30%", text: "市町村ごとに料金が異なる。粗大ごみは品目別の処分費" },
  { label: "オプション費", percent: "5-15%", text: "簡易清掃・特殊清掃・供養・ハウスクリーニング等" },
  { label: "買取相殺", percent: "△10-30%", text: "価値ある遺品を買取して費用から差し引く。骨董・貴金属がある場合は大幅減額の可能性" },
];

const cheapTraps = [
  { title: "「作業一式◯◯円」の丸めた見積もり", risk: "内訳不明だと、当日に「想定より荷物が多い」「分別追加」等で追加請求の温床" },
  { title: "電話だけで即決した見積もり", risk: "現地確認なしの見積もりは精度が低く、追加料金が発生しがち" },
  { title: "極端に安い「1K ¥10,000〜」", risk: "相場乖離は不法投棄や追加請求のサイン。市相場の半額以下は要警戒" },
  { title: "現金前払いの強要", risk: "正規業者は作業後精算が標準。前払いは作業放棄リスクあり" },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "徳丸商会トップ", "item": homeUrl },
      { "@type": "ListItem", "position": 2, "name": "ガイド", "item": guideIndexUrl },
      { "@type": "ListItem", "position": 3, "name": "遺品整理の費用相場", "item": pageUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "遺品整理の費用相場｜名古屋市の間取り別実勢価格と内訳の見方",
    "description": description,
    "author": { "@id": `${homeUrl}#localbusiness` },
    "publisher": { "@id": `${homeUrl}#localbusiness` },
    "mainEntityOfPage": pageUrl,
    "datePublished": "2026-04-26",
    "dateModified": "2026-04-26",
    "about": [
      { "@type": "Thing", "name": "遺品整理 費用" },
      { "@type": "Thing", "name": "遺品整理 相場" },
      { "@type": "Thing", "name": "見積書 内訳" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "PriceSpecification",
    "name": "遺品整理 名古屋市 間取り別料金目安",
    "priceCurrency": "JPY",
    "minPrice": "30000",
    "maxPrice": "240000",
    "valueAddedTaxIncluded": true,
  },
];
---

<Layout title={title} description={description} extraJsonLd={structuredData}>

<header class="fixed top-0 inset-x-0 z-50 shadow-lg">
  <div class="hidden md:flex bg-teal-dark text-white text-xs py-1 px-5 justify-end items-center gap-6">
    <span class="whitespace-nowrap">受付 9:00〜21:00 年中無休</span>
    <span class="whitespace-nowrap">古物商許可 第541042309800号</span>
  </div>
  <div class="bg-white/95 backdrop-blur-md border-b border-teal/10">
    <div class="max-w-6xl mx-auto px-4 h-[60px] md:h-[72px] flex items-center justify-between">
      <a href={homePath} class="flex items-center gap-2.5 shrink-0">
        <img src={logo} alt="徳丸商会ロゴ" width="48" height="48" class="w-11 h-11 md:w-14 md:h-14" loading="eager" />
        <div>
          <div class="text-teal-dark font-black text-base md:text-xl leading-tight whitespace-nowrap">徳丸商会</div>
          <div class="text-text-lighter text-[9px] md:text-xs font-bold leading-tight whitespace-nowrap">遺品整理ガイド</div>
        </div>
      </a>
      <div class="flex items-center gap-2 shrink-0">
        <a href="tel:052-990-3968" class="flex items-center justify-center gap-1.5 bg-orange hover:bg-orange-light text-white font-bold text-[11px] md:text-sm px-3 md:px-4 py-2 md:py-2.5 rounded-lg md:rounded-xl whitespace-nowrap shadow-sm transition-colors">電話</a>
        <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-1.5 bg-line hover:brightness-110 text-white font-bold text-[11px] md:text-sm px-3 md:px-4 py-2 md:py-2.5 rounded-lg md:rounded-xl whitespace-nowrap shadow-sm transition-all">LINE</a>
      </div>
    </div>
  </div>
</header>

<main class="pt-[60px] md:pt-[calc(1.75rem+4.5rem)]">

<nav aria-label="パンくず" class="bg-bg border-b border-border py-3">
  <div class="max-w-6xl mx-auto px-5 text-xs text-text-light">
    <a href={homePath} class="hover:text-teal">トップ</a>
    <span class="mx-2 text-text-lighter">/</span>
    <a href={`${basePath}guide/`} class="hover:text-teal">ガイド</a>
    <span class="mx-2 text-text-lighter">/</span>
    <span class="text-text">遺品整理の費用相場</span>
  </div>
</nav>

<section class="bg-teal-dark text-white py-16 md:py-24">
  <div class="max-w-4xl mx-auto px-5">
    <p class="text-orange-light text-xs md:text-sm font-bold mb-3 tracking-wider">遺品整理ガイド</p>
    <h1 class="text-2xl md:text-4xl lg:text-5xl font-black leading-[1.2] mb-5">
      <span class="text-orange-light">遺品整理の費用相場</span><br />
      <span class="text-lg md:text-2xl font-bold text-white/85">名古屋市の間取り別実勢価格と内訳の見方</span>
    </h1>
    <p class="text-white/85 text-sm md:text-base leading-relaxed">
      名古屋市の遺品整理費用は1K¥30,000〜、3LDK¥150,000〜が相場帯。<br />
      ただし「内訳の見方」「追加料金の罠」を知らないと、相場の倍以上を請求されるケースもあります。  本ガイドで適正価格の見極め方を整理します。
    </p>
  </div>
</section>

<!-- 結論先出し -->
<section class="py-12 md:py-16 bg-white border-b border-border">
  <div class="max-w-3xl mx-auto px-5">
    <div class="bg-teal/5 border-l-4 border-teal rounded-r-2xl p-5 md:p-6">
      <p class="text-teal-dark font-black text-base md:text-lg mb-3">📌 名古屋の費用相場ざっくりまとめ</p>
      <ul class="text-text leading-[1.9] text-sm md:text-base space-y-2 list-disc pl-5">
        <li>1K・1DK：<strong class="text-teal-dark">¥30,000〜¥70,000</strong></li>
        <li>1LDK・2DK：<strong class="text-teal-dark">¥60,000〜¥120,000</strong></li>
        <li>2LDK・3DK：<strong class="text-teal-dark">¥100,000〜¥180,000</strong></li>
        <li>3LDK・4DK：<strong class="text-teal-dark">¥150,000〜¥240,000</strong></li>
        <li><strong class="text-orange">骨董品・貴金属が出れば買取で大幅軽減</strong>（10〜30%減）</li>
      </ul>
    </div>
  </div>
</section>

<!-- 間取り別 -->
<section class="py-14 md:py-20 bg-bg">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-xl md:text-3xl font-black text-center text-teal-dark mb-3">
      名古屋市の<span class="text-orange">間取り別 費用相場</span>
    </h2>
    <p class="text-text-light text-sm text-center mb-8">荷物量・特殊清掃の有無により上下します</p>

    <div class="bg-white rounded-2xl border border-border overflow-hidden shadow-sm">
      <div class="bg-teal text-white text-center py-3 font-black text-sm">名古屋市の遺品整理 概算料金表</div>
      <table class="w-full text-sm md:text-base">
        <thead>
          <tr class="bg-bg-gray text-text">
            <th class="py-3 px-3 md:px-4 text-left font-bold">間取り</th>
            <th class="py-3 px-3 md:px-4 text-left font-bold hidden md:table-cell">想定シーン</th>
            <th class="py-3 px-3 md:px-4 text-center font-bold whitespace-nowrap">相場帯</th>
            <th class="py-3 px-3 md:px-4 text-center font-bold whitespace-nowrap hidden sm:table-cell">作業時間</th>
          </tr>
        </thead>
        <tbody>
          {feeRows.map((r, i) => (
            <tr class={i % 2 === 0 ? "bg-white" : "bg-bg-light"}>
              <td class="py-3 px-3 md:px-4 font-bold text-teal-dark whitespace-nowrap">{r.size}</td>
              <td class="py-3 px-3 md:px-4 text-text-light text-xs md:text-sm hidden md:table-cell">{r.scene}</td>
              <td class="py-3 px-3 md:px-4 text-center font-bold text-orange whitespace-nowrap">{r.market}</td>
              <td class="py-3 px-3 md:px-4 text-center text-text-light text-xs md:text-sm hidden sm:table-cell">{r.time}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-text-lighter text-xs text-center mt-4">※ 上記は名古屋市内の一般的な相場。荷物量・階段運搬・特殊清掃・遠方の有無で上下します</p>
  </div>
</section>

<!-- 内訳 -->
<section class="py-14 md:py-20 bg-white">
  <div class="max-w-3xl mx-auto px-5">
    <h2 class="text-xl md:text-3xl font-black text-teal-dark mb-3 text-center">
      料金の<span class="text-orange">内訳</span>を知れば、適正かどうか判断できます
    </h2>
    <p class="text-text-light text-sm text-center mb-10">優良業者は必ず内訳を提示します</p>

    <div class="space-y-3">
      {breakdown.map(b => (
        <div class="flex items-start gap-4 bg-bg-light border border-border rounded-xl p-4 md:p-5">
          <div class="shrink-0 w-16 md:w-20 text-center">
            <p class="text-orange font-black text-base md:text-xl whitespace-nowrap">{b.percent}</p>
          </div>
          <div class="flex-1 border-l border-border pl-4">
            <p class="text-teal-dark font-black text-sm md:text-base mb-1">{b.label}</p>
            <p class="text-text-light text-xs md:text-sm leading-relaxed">{b.text}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 bg-orange/5 border border-orange/30 rounded-xl p-5">
      <p class="text-orange font-black text-sm md:text-base mb-2">💡 徳丸商会の強み</p>
      <p class="text-text text-sm md:text-base leading-relaxed">
        徳丸商会は専門査定員による <strong>骨董品・貴金属・着物・茶道具の専門査定</strong> が可能なため、
        他社で「処分扱い」される品でも価値を見いだして買取できる場合があります。
        結果として整理費用が10〜30%軽減されるケースが少なくありません。
      </p>
    </div>
  </div>
</section>

<!-- 安いの罠 -->
<section class="py-14 md:py-20 bg-bg">
  <div class="max-w-3xl mx-auto px-5">
    <h2 class="text-xl md:text-3xl font-black text-teal-dark mb-3 text-center">
      <span class="text-red">「安い見積書」</span>に潜む4つの罠
    </h2>
    <p class="text-text-light text-sm text-center mb-10">相場の半額以下は要注意。後から追加請求や不法投棄リスクあり</p>

    <div class="space-y-4">
      {cheapTraps.map((t, i) => (
        <div class="bg-white border border-red/20 rounded-xl p-5 md:p-6">
          <p class="text-red font-black text-base md:text-lg mb-2">
            <span class="bg-red/10 text-red text-xs font-black px-2 py-0.5 rounded mr-2">罠{i + 1}</span>
            {t.title}
          </p>
          <p class="text-text-light text-sm md:text-base leading-relaxed">{t.risk}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 比較ポイント -->
<section class="py-14 md:py-20 bg-white">
  <div class="max-w-3xl mx-auto px-5">
    <h2 class="text-xl md:text-3xl font-black text-teal-dark mb-3 text-center">
      費用を抑える<span class="text-orange">3つの方法</span>
    </h2>
    <p class="text-text-light text-sm text-center mb-10">適正価格＋αで安く済ませる現実的なアプローチ</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {[
        { num: "①", title: "買取と整理を同時依頼", text: "別々に頼むより、買取込みで依頼すると相殺で実質料金が下がります。徳丸商会では骨董・貴金属が特に強い" },
        { num: "②", title: "形見分けを先に済ませる", text: "親族で必要な物を引き取ってから依頼すると、回収量が減り料金が下がります" },
        { num: "③", title: "繁忙期を避ける", text: "3月（年度末）と12月（年末）は混雑。可能なら4-6月・9-11月が動きやすいです" },
      ].map(p => (
        <div class="bg-bg-light border border-border rounded-2xl p-5">
          <p class="text-orange font-black text-2xl md:text-3xl mb-2">{p.num}</p>
          <p class="text-teal-dark font-black text-base mb-2">{p.title}</p>
          <p class="text-text-light text-xs md:text-sm leading-relaxed">{p.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-14 md:py-20 bg-teal-dark text-white">
  <div class="max-w-3xl mx-auto px-5 text-center">
    <h2 class="text-xl md:text-3xl font-black mb-4">
      具体的な料金は<br class="md:hidden" />お電話・LINEでご案内します
    </h2>
    <p class="text-white/85 text-sm md:text-base mb-8 leading-relaxed">
      間取りと荷物量をお伝えいただければ、概算をその場でご案内。<br />
      LINEなら写真を送るだけで概算見積もりが届きます。
    </p>
    <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <a href="tel:052-990-3968" class="cta-glow flex-1 bg-orange hover:bg-orange-light text-white font-black text-base py-4 rounded-xl shadow-xl whitespace-nowrap transition-colors">電話で無料相談</a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="cta-glow-line flex-1 bg-line hover:brightness-110 text-white font-black text-base py-4 rounded-xl shadow-xl whitespace-nowrap transition-all">LINE 5%OFF査定</a>
    </div>
  </div>
</section>

<!-- 関連ガイド -->
<section class="py-12 md:py-16 bg-white border-t border-border">
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-base md:text-xl font-black text-teal-dark mb-6 text-center">関連ガイド</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <a href={`${basePath}guide/parent-passing/`} class="block bg-bg hover:bg-teal hover:text-white rounded-xl p-5 transition-colors group">
        <p class="text-teal-dark group-hover:text-white font-bold text-sm md:text-base mb-1">親が亡くなった後の遺品整理</p>
        <p class="text-text-light group-hover:text-white/80 text-xs">葬儀後〜10ヶ月のやることカレンダー →</p>
      </a>
      <a href={`${basePath}guide/scam-check/`} class="block bg-bg hover:bg-teal hover:text-white rounded-xl p-5 transition-colors group">
        <p class="text-teal-dark group-hover:text-white font-bold text-sm md:text-base mb-1">悪徳業者の見分け方</p>
        <p class="text-text-light group-hover:text-white/80 text-xs">許認可と見積書の10チェックポイント →</p>
      </a>
    </div>
  </div>
</section>

</main>

</Layout>
