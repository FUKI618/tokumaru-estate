---
import Layout from "../../layouts/Layout.astro";
import { areas, areasByRegion, regionOrder } from "../../data/areas";
import { assetPath, basePath, homePath } from "../../lib/site";

const logo = assetPath("logo.svg");

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const pageUrl = new URL(`${basePath}area/`, siteUrl).toString();
const homeUrl = new URL(homePath, siteUrl).toString();

const title = "対応エリア一覧｜名古屋市16区・愛知県全域の遺品整理｜徳丸商会";
const description = `徳丸商会の遺品整理・生前整理対応エリア一覧。名古屋市16区＋尾張・知多・西三河・東三河・三重県北部の${areas.length}エリアで出張対応。出張費・査定費0円、立会い不要OK。052-990-3968`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "徳丸商会トップ", "item": homeUrl },
      { "@type": "ListItem", "position": 2, "name": "対応エリア一覧", "item": pageUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "徳丸商会 対応エリア一覧",
    "numberOfItems": areas.length,
    "itemListElement": areas.map((area, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": area.name,
      "url": new URL(`${basePath}area/${area.slug}/`, siteUrl).toString(),
    })),
  },
];

// Region に存在しないエリアもグルーピングできるようフォールバック
const regionsWithAreas = regionOrder.filter(r => areasByRegion[r] && areasByRegion[r]!.length > 0);
---

<Layout title={title} description={description} extraJsonLd={structuredData}>

<header class="fixed top-0 inset-x-0 z-50 shadow-lg">
  <div class="hidden md:flex bg-teal-dark text-white text-xs py-1 px-5 justify-end items-center gap-6">
    <span class="whitespace-nowrap">受付 9:00〜21:00 年中無休</span>
    <span class="whitespace-nowrap">古物商許可 第541042309800号</span>
  </div>
  <div class="bg-white/95 backdrop-blur-md border-b border-teal/10">
    <div class="max-w-6xl mx-auto px-4 h-[60px] md:h-[72px] flex items-center justify-between">
      <a href={homePath} class="flex items-center gap-2.5 shrink-0">
        <img src={logo} alt="徳丸商会ロゴ" width="48" height="48" class="w-11 h-11 md:w-14 md:h-14" loading="eager" />
        <div>
          <div class="text-teal-dark font-black text-base md:text-xl leading-tight whitespace-nowrap">徳丸商会</div>
          <div class="text-text-lighter text-[9px] md:text-xs font-bold leading-tight whitespace-nowrap">遺品整理・生前整理専門</div>
        </div>
      </a>
      <div class="flex items-center gap-2 shrink-0">
        <a href="tel:052-990-3968" class="flex items-center justify-center gap-1.5 bg-orange hover:bg-orange-light text-white font-bold text-[11px] md:text-sm px-3 md:px-4 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-colors whitespace-nowrap shadow-sm">電話</a>
        <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-1.5 bg-line hover:brightness-110 text-white font-bold text-[11px] md:text-sm px-3 md:px-4 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap shadow-sm">LINE</a>
      </div>
    </div>
  </div>
</header>

<main class="pt-[60px] md:pt-[calc(1.75rem+4.5rem)]">

<nav aria-label="パンくず" class="bg-bg border-b border-border py-3">
  <div class="max-w-6xl mx-auto px-5 text-xs text-text-light">
    <a href={homePath} class="hover:text-teal">トップ</a>
    <span class="mx-2 text-text-lighter">/</span>
    <span class="text-text">対応エリア一覧</span>
  </div>
</nav>

<section class="py-14 md:py-20 bg-teal-dark text-white">
  <div class="max-w-5xl mx-auto px-5 text-center">
    <h1 class="text-2xl md:text-4xl font-black mb-4 leading-tight">
      徳丸商会の<span class="text-orange-light">対応エリア一覧</span>
    </h1>
    <p class="text-white/85 text-sm md:text-base leading-relaxed max-w-2xl mx-auto">
      名古屋市16区を中心に、尾張・知多・西三河・東三河、三重県北部の<strong class="text-orange-light">{areas.length}エリア</strong>で<br class="hidden sm:block" />遺品整理・生前整理に出張対応しています。
    </p>
    <p class="text-white/65 text-xs md:text-sm mt-3">出張費・査定費0円／立会い不要OK／即日対応可</p>
  </div>
</section>

{regionsWithAreas.map(region => (
  <section class="py-12 md:py-16 even:bg-bg odd:bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-5">
      <div class="flex items-baseline gap-3 mb-7 md:mb-9">
        <h2 class="text-lg md:text-2xl font-black text-teal-dark">{region}</h2>
        <span class="text-text-lighter text-xs">{areasByRegion[region]!.length}エリア</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {areasByRegion[region]!.map(area => (
          <a href={`${basePath}area/${area.slug}/`} class="block bg-white border border-border hover:border-teal hover:shadow-md rounded-2xl p-5 transition-all group">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="text-teal-dark font-black text-base group-hover:text-teal transition-colors">{area.name}</h3>
              <span class="text-orange text-xs shrink-0 mt-1">→</span>
            </div>
            <p class="text-text-light text-xs leading-relaxed mb-3 line-clamp-3">{area.characteristic}</p>
            <div class="flex flex-wrap gap-1.5">
              {area.buyoutFocus.slice(0, 3).map(item => (
                <span class="bg-teal/10 text-teal text-[10px] font-bold px-2 py-0.5 rounded-full">{item}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
))}

<section class="py-14 md:py-20 bg-teal-dark text-white">
  <div class="max-w-3xl mx-auto px-5 text-center">
    <h2 class="text-xl md:text-2xl font-black mb-4">
      上記エリア以外の方もまずはご相談ください
    </h2>
    <p class="text-white/80 text-sm mb-8 leading-relaxed">
      対応可否はお電話・LINEでお気軽にお問い合わせください。<br />
      隣接地域へも条件次第でお伺いしています。
    </p>
    <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <a href="tel:052-990-3968" class="cta-glow flex-1 bg-orange hover:bg-orange-light text-white font-black text-base py-4 rounded-xl shadow-xl whitespace-nowrap transition-colors">電話で無料相談</a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="cta-glow-line flex-1 bg-line hover:brightness-110 text-white font-black text-base py-4 rounded-xl shadow-xl whitespace-nowrap transition-all">LINEで査定</a>
    </div>
  </div>
</section>

</main>

</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
