---
import Layout from "../layouts/Layout.astro";
import { assetPath, homePath, sectionPath, privacyPolicyPath } from "../lib/site";

const logo = assetPath("logo.png");
const before = assetPath("images/before.png");
const after = assetPath("images/after.png");

const buyItems = [
  "仏壇・仏具", "着物・和装品", "骨董品・美術品", "金・プラチナ・貴金属",
  "ダイヤモンド・宝石", "腕時計（ロレックス等）", "ブランドバッグ・財布",
  "家電（冷蔵庫・洗濯機・エアコン）", "家具（タンス・食器棚）", "食器・陶器",
  "カメラ・光学機器", "楽器", "古銭・切手・記念硬貨", "お酒（日本酒・ワイン・ウイスキー）",
  "掛軸・絵画", "書道具・茶道具",
];

const faqItems = [
  { q: "遺品整理業者との違いは何ですか？", a: "遺品整理業者は片付け・処分がメインですが、徳丸商会はお品物の「買取」に特化しています。まず当社で価値あるお品物を買い取り、その後に整理業者に依頼することで、整理費用を大幅に抑えられます。" },
  { q: "古いものばかりで価値があるかわかりません。それでも来てもらえますか？", a: "もちろんです。骨董品・古美術品・古いブランド品など、一見価値がわからないお品物にも値段がつくことがあります。出張費・査定費は無料ですので、お気軽にご依頼ください。" },
  { q: "故人の家が遠方ですが対応できますか？", a: "お立ち会いが難しい場合でも、鍵の受け渡しと写真報告で対応可能です。愛知県名古屋市を中心に、近郊エリアへ出張いたします。" },
  { q: "仏壇や位牌の供養もお願いできますか？", a: "提携寺院での合同供養に対応しております。個別供養のご相談も承ります。" },
  { q: "相続で揉めているのですが、査定だけお願いできますか？", a: "はい、査定のみのご依頼も承っております。査定書の発行も可能ですので、相続の際の参考資料としてご活用ください。" },
  { q: "大量の品物がありますが、一日で終わりますか？", a: "品物の量にもよりますが、スタッフ複数名で対応し、できる限り1日で完了するよう努めます。事前にLINEで写真を送っていただければ、所要時間の目安をお伝えできます。" },
];

const voices = [
  { text: "母の遺品が大量にあり途方に暮れていましたが、着物や骨董品に思わぬ値段がつき、整理費用をまかなえました。", who: "名古屋市千種区 K.M様", tag: "遺品整理" },
  { text: "父が集めていた古銭コレクション、他社では断られましたが、こちらではしっかり査定していただけました。", who: "名古屋市中区 S.T様", tag: "古銭買取" },
  { text: "生前整理で家を片付けたいと相談したところ、家電から貴金属まで全部まとめて対応してくれて助かりました。", who: "清須市 A.N様", tag: "生前整理" },
];

const areas = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearby = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市"];
---

<Layout
  title="名古屋の生前整理・遺品買取なら徳丸商会｜出張費無料・その場で現金"
  description="名古屋市で生前整理・遺品買取なら徳丸商会。骨董品・貴金属・着物・家電まで幅広く出張買取。遺品整理の前に買取査定で費用を軽減。出張費0円。052-990-3968"
>

<!-- HEADER -->
<header class="fixed top-0 inset-x-0 z-50 bg-main shadow-md">
  <div class="max-w-6xl mx-auto px-5 h-14 flex items-center justify-between">
    <a href={homePath} class="flex items-center gap-2">
      <img src={logo} alt="徳丸商会" width="32" height="32" class="w-8 h-8" />
      <span class="text-white font-bold text-sm">徳丸商会</span>
    </a>
    <div class="flex items-center gap-2">
      <a href="tel:052-990-3968" class="flex items-center gap-1.5 bg-white/15 hover:bg-white/25 text-white font-bold text-xs px-3 py-1.5 rounded transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="hidden sm:inline">052-990-3968</span>
      </a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-hot hover:bg-hot-light text-white font-bold text-xs px-3 py-1.5 rounded transition-colors">無料査定</a>
    </div>
  </div>
</header>

<main class="pt-14">

<!-- HERO -->
<section class="bg-main text-white py-12 md:py-20">
  <div class="max-w-6xl mx-auto px-5">
    <div class="md:flex md:items-center md:gap-10">
      <div class="md:flex-1 mb-8 md:mb-0">
        <div class="inline-block bg-hot text-white text-xs font-bold px-3 py-1 rounded mb-4">生前整理・遺品買取 強化中</div>
        <h1 class="text-xl md:text-3xl lg:text-4xl font-black leading-tight mb-4">
          遺品整理の前に、<br />まず「買取」を<br />ご検討ください
        </h1>
        <p class="text-white/70 text-sm leading-relaxed mb-6 max-w-md">
          故人の大切なお品物、処分する前に価値を確かめませんか。骨董品・貴金属・着物・家電まで、経験豊富なスタッフがご自宅で丁寧に査定。買取額を整理費用に充てることで、ご負担を大幅に軽減できます。
        </p>
        <div class="flex flex-wrap gap-3 mb-4">
          <a href="tel:052-990-3968" class="bg-hot hover:bg-hot-light text-white font-bold text-sm px-6 py-3 rounded transition-colors">今すぐ電話 052-990-3968</a>
          <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-line hover:opacity-90 text-white font-bold text-sm px-6 py-3 rounded transition-opacity">LINEで写真査定</a>
        </div>
        <div class="flex flex-wrap gap-4 text-xs text-white/50">
          <span>✓ 出張費0円</span><span>✓ 査定のみOK</span><span>✓ 即日対応</span><span>✓ その場で現金</span>
        </div>
      </div>
      <div class="md:w-[360px] flex-shrink-0 grid grid-cols-3 gap-3">
        <div class="bg-white/10 rounded p-4 text-center">
          <p class="text-2xl md:text-3xl font-black text-hot leading-none">0</p>
          <p class="text-xs text-white/60 mt-1">出張費・<br/>査定費</p>
        </div>
        <div class="bg-white/10 rounded p-4 text-center">
          <p class="text-2xl md:text-3xl font-black text-hot leading-none">98</p>
          <p class="text-xs text-white/60 mt-1">満足度<br/>（%）</p>
        </div>
        <div class="bg-white/10 rounded p-4 text-center">
          <p class="text-2xl md:text-3xl font-black text-hot leading-none">30</p>
          <p class="text-xs text-white/60 mt-1">最短<br/>（分）</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- お悩み -->
<section class="py-14 md:py-20">
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-main mb-8">生前整理・遺品の処分にお悩みではありませんか？</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {[
        "遺品が大量にあり、何から手をつけていいかわからない",
        "骨董品や貴金属の価値がわからず処分できない",
        "遺品整理業者の費用が高くて困っている",
        "故人の家が遠方で立ち会えない",
        "形見分けの後、残ったものをどうすればいいか",
        "生前に持ち物を整理しておきたい",
      ].map(pain => (
        <div class="flex items-start gap-3 bg-bg-white rounded p-4 border border-bg-dark">
          <span class="text-hot font-bold text-sm mt-0.5">✓</span>
          <p class="text-text text-sm">{pain}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 遺品整理業者との違い -->
<section class="py-14 md:py-20 bg-bg-white">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-main mb-3">
      遺品整理を依頼する前に「出張買取」をご検討ください
    </h2>
    <p class="text-text-light text-sm mb-10 max-w-2xl mx-auto">
      遺品整理業者は片付け・処分がメインのサービスです。徳丸商会の出張買取を先にご利用いただくことで、価値あるお品物を現金に換え、整理費用に充てることができます。
    </p>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse max-w-2xl mx-auto">
        <thead>
          <tr>
            <th class="bg-main text-white px-4 py-3 text-left rounded-tl">比較</th>
            <th class="bg-main text-white px-4 py-3 text-center">遺品整理業者</th>
            <th class="bg-hot text-white px-4 py-3 text-center rounded-tr">徳丸商会の買取</th>
          </tr>
        </thead>
        <tbody>
          {[
            ["費用", "数万〜数十万円かかる", "無料（逆に現金GET）"],
            ["対応", "片付け・処分", "査定・現金買取"],
            ["お品物", "まとめて処分", "価値を見極めて買取"],
            ["メリット", "一括で片付く", "費用を大幅軽減できる"],
          ].map(([label, a, b], i) => (
            <tr class={i % 2 === 0 ? "bg-bg" : "bg-bg-white"}>
              <td class="px-4 py-3 font-bold text-text">{label}</td>
              <td class="px-4 py-3 text-center text-text-light">{a}</td>
              <td class="px-4 py-3 text-center text-hot font-bold">{b}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-main font-bold text-sm text-center mt-6">
      → まず徳丸商会で買取 → その後に整理業者に依頼 = 最もお得な順序です
    </p>
  </div>
</section>

<!-- 買取対象品目 -->
<section id="items" class="py-14 md:py-20">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-main mb-3">様々な遺品・お品物を買い取ります</h2>
    <p class="text-text-light text-sm mb-8 max-w-lg mx-auto">「こんなものでも売れるの？」とよく聞かれますが、実は値段がつくものは多いです。</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
      {buyItems.map(item => (
        <div class="bg-bg-white rounded p-3 border border-bg-dark text-sm text-text font-medium text-center">{item}</div>
      ))}
    </div>
    <div class="mt-6 bg-hot/5 border border-hot/20 rounded p-4 max-w-2xl mx-auto">
      <p class="text-text text-sm">
        <strong class="text-hot">状態が悪くても大丈夫：</strong>シミのある着物、箱なしの食器、動かない時計、欠けた陶器など、状態に関わらずまずはご相談ください。
      </p>
    </div>
  </div>
</section>

<!-- 選ばれる理由 -->
<section class="py-14 md:py-20 bg-bg-white">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-main mb-10">生前整理・遺品買取で徳丸商会が選ばれる理由</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {[
        { n: "01", t: "幅広い品目を一括査定", d: "骨董品から家電まで、ジャンルを問わずまとめて査定。複数の買取業者を呼ぶ手間が省けます。" },
        { n: "02", t: "遺品に配慮した丁寧な対応", d: "故人の大切なお品物を、経験豊富なスタッフが一つひとつ丁寧に査定いたします。" },
        { n: "03", t: "出張費・査定費 完全無料", d: "費用は一切かかりません。査定だけ・相談だけでもお気軽にどうぞ。" },
        { n: "04", t: "買取額で整理費用を軽減", d: "思わぬお品物に値段がつき、遺品整理の費用をまかなえたケースも多数あります。" },
      ].map(r => (
        <div class="flex gap-4 bg-bg rounded p-5 border border-bg-dark">
          <span class="text-2xl font-black text-hot/30">{r.n}</span>
          <div>
            <p class="text-main font-bold text-sm mb-1">{r.t}</p>
            <p class="text-text-light text-sm leading-relaxed">{r.d}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 流れ -->
<section class="py-14 md:py-20 bg-main text-white">
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center mb-10">出張買取の流れ</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { n: "STEP 01", t: "お電話・LINEでご相談", d: "お品物の内容と訪問日時をお伝えください。LINEなら写真で事前査定も可能です。" },
        { n: "STEP 02", t: "ご訪問・査定・現金払い", d: "スタッフがご自宅にお伺いし、一点ずつ丁寧に査定。その場で現金をお渡しします。" },
        { n: "STEP 03", t: "搬出・お片付け完了", d: "買取品はそのまま搬出。残ったお品物の整理業者紹介も可能です。" },
      ].map(s => (
        <div class="bg-white/10 rounded p-5">
          <span class="text-hot text-xs font-bold">{s.n}</span>
          <h3 class="text-white font-bold text-sm mt-2 mb-1">{s.t}</h3>
          <p class="text-white/60 text-sm leading-relaxed">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 中間CTA -->
<section class="py-10 bg-hot text-white text-center">
  <div class="max-w-3xl mx-auto px-5">
    <p class="font-bold text-sm md:text-base mb-3">処分する前に、まず無料査定を。</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="tel:052-990-3968" class="bg-white text-hot font-bold text-sm px-6 py-3 rounded hover:opacity-90 transition-opacity">052-990-3968</a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-line text-white font-bold text-sm px-6 py-3 rounded hover:opacity-90 transition-opacity">LINEで査定</a>
    </div>
  </div>
</section>

<!-- ビフォーアフター -->
<section class="py-14 md:py-20">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-main mb-10">まるっと回収の実例</h2>
    <div class="grid grid-cols-2 gap-3 md:gap-6 max-w-3xl mx-auto">
      <div>
        <div class="bg-text text-white text-xs font-bold text-center py-1 rounded-t">Before</div>
        <img src={before} alt="回収前" class="w-full rounded-b" loading="lazy" />
      </div>
      <div>
        <div class="bg-hot text-white text-xs font-bold text-center py-1 rounded-t">After</div>
        <img src={after} alt="回収後" class="w-full rounded-b" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- お客様の声 -->
<section class="py-14 md:py-20 bg-bg-white">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-main mb-10">生前整理・遺品買取のお客様の声</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {voices.map(v => (
        <div class="bg-bg rounded p-5 border border-bg-dark">
          <span class="inline-block bg-main text-white text-xs font-bold px-2 py-0.5 rounded mb-3">{v.tag}</span>
          <div class="flex gap-1 mb-2">{Array.from({length:5}).map(() => <span class="text-hot text-sm">★</span>)}</div>
          <p class="text-text text-sm leading-relaxed mb-3">{v.text}</p>
          <p class="text-text-lighter text-xs">{v.who}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 対応エリア -->
<section id="area" class="py-14 md:py-20">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-main mb-10">出張買取対応エリア</h2>
    <div class="md:flex md:gap-12">
      <div class="mb-6 md:mb-0">
        <h3 class="text-main font-bold text-sm mb-3">名古屋市（16区）</h3>
        <div class="flex flex-wrap gap-x-3 gap-y-1 text-text-light text-sm">{areas.map(w => <span>{w}</span>)}</div>
      </div>
      <div>
        <h3 class="text-main font-bold text-sm mb-3">近郊エリア</h3>
        <div class="flex flex-wrap gap-x-3 gap-y-1 text-text-light text-sm">{nearby.map(a => <span>{a}</span>)}</div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="py-14 md:py-20 bg-bg-white">
  <div class="max-w-3xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-main mb-10">生前整理・遺品買取のよくあるご質問</h2>
    <div class="divide-y divide-bg-dark">
      {faqItems.map(faq => (
        <div x-data="{ open: false }">
          <button x-on:click="open = !open" class="w-full flex items-start justify-between gap-4 py-5 text-left" x-bind:aria-expanded="open.toString()">
            <span class="text-text font-bold text-sm leading-relaxed">{faq.q}</span>
            <span class="text-hot text-base flex-shrink-0 transition-transform duration-200" x-bind:class="open && 'rotate-45'">+</span>
          </button>
          <div x-show="open" x-transition class="pb-5" style="display: none;">
            <p class="text-text-light text-sm leading-relaxed">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section id="contact" class="py-16 md:py-24 bg-main text-white text-center">
  <div class="max-w-2xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black mb-3">処分する前に、まずはお電話を。</h2>
    <p class="text-white/60 text-sm mb-8">「こんなものでも売れるの？」というご相談だけでも大歓迎です。</p>
    <div class="flex flex-wrap justify-center gap-3 mb-4">
      <a href="tel:052-990-3968" class="bg-hot hover:bg-hot-light text-white font-bold text-sm px-7 py-3.5 rounded transition-colors">052-990-3968</a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-line hover:opacity-90 text-white font-bold text-sm px-7 py-3.5 rounded transition-opacity">LINEで無料査定</a>
    </div>
    <p class="text-white/30 text-xs">受付 9:00–21:00 年中無休 ｜ 古物商許可 第541042309800号</p>
  </div>
</section>

</main>

<!-- FOOTER -->
<footer class="bg-text text-white/40 py-12">
  <div class="max-w-6xl mx-auto px-5 md:flex md:justify-between md:items-start gap-10">
    <div class="mb-6 md:mb-0">
      <div class="flex items-center gap-2 mb-2">
        <img src={logo} alt="徳丸商会" width="24" height="24" class="w-6 h-6" />
        <span class="text-white/60 font-bold text-sm">徳丸商会</span>
      </div>
      <p class="text-xs">名古屋の生前整理・遺品買取</p>
      <p class="text-xs">古物商許可 第541042309800号</p>
    </div>
    <div class="flex gap-10 text-xs">
      <div>
        <p class="text-white/50 text-xs uppercase tracking-wider mb-2">Contact</p>
        <a href="tel:052-990-3968" class="block hover:text-white/60 transition-colors mb-1">052-990-3968</a>
        <p>9:00–21:00（年中無休）</p>
      </div>
