---
import Layout from "../layouts/Layout.astro";
import { assetPath, homePath, sectionPath, privacyPolicyPath } from "../lib/site";

const logo = assetPath("logo.png");
const before = assetPath("images/before.png");
const after = assetPath("images/after.png");

const buyItems = [
  "仏壇・仏具","着物・和装品","骨董品・美術品","金・プラチナ・貴金属",
  "ダイヤモンド・宝石","腕時計","ブランドバッグ","家電製品",
  "家具","食器・陶器","カメラ","楽器","古銭・切手","お酒","掛軸・絵画","茶道具・書道具",
];
const faqItems = [
  { q: "遺品整理業者との違いは何ですか？", a: "遺品整理業者は片付け・処分がメインですが、当社はお品物の「買取」に特化しています。先に買取を行うことで整理費用を大幅に抑えられます。" },
  { q: "古いものばかりですが買取できますか？", a: "骨董品・古美術品など、一見価値がわからないお品物にも値段がつくことがあります。出張費・査定費は無料ですのでお気軽にどうぞ。" },
  { q: "故人の家が遠方で立ち会えません", a: "鍵の受け渡しと写真報告で対応可能です。愛知県名古屋市を中心に近郊エリアへ出張します。" },
  { q: "仏壇や位牌の供養もお願いできますか？", a: "提携寺院での合同供養に対応しております。個別供養のご相談も承ります。" },
  { q: "査定だけお願いすることはできますか？", a: "はい。査定のみのご依頼も承っています。査定書の発行も可能です。" },
  { q: "状態の悪いものでも大丈夫ですか？", a: "シミのある着物、動かない時計、箱なしの食器など、状態に関わらずまずご相談ください。" },
];
const voices = [
  { text: "母の遺品が大量にあり途方に暮れていましたが、着物や骨董品に思わぬ値段がつき、整理費用をまかなえました。", who: "名古屋市千種区 K.M様" },
  { text: "父が集めていた古銭コレクション、他社では断られましたがこちらではしっかり査定していただけました。", who: "名古屋市中区 S.T様" },
  { text: "生前整理で家電から貴金属まで全部まとめて対応してくれて助かりました。", who: "清須市 A.N様" },
];
const areas = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearby = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市"];
---

<Layout
  title="名古屋の生前整理・遺品買取なら徳丸商会｜出張費無料・その場で現金"
  description="名古屋市で生前整理・遺品買取なら徳丸商会。骨董品・貴金属・着物・家電まで出張買取。遺品整理の前に買取で費用軽減。出張費0円。052-990-3968"
>

<!-- HEADER: ティール -->
<header class="fixed top-0 inset-x-0 z-50 bg-teal shadow-md">
  <div class="max-w-6xl mx-auto px-5 h-14 flex items-center justify-between">
    <a href={homePath} class="flex items-center gap-2">
      <img src={logo} alt="徳丸商会" width="32" height="32" class="w-8 h-8" />
      <div class="leading-tight">
        <span class="text-white font-bold text-sm block">徳丸商会</span>
        <span class="text-white/50 text-[9px]">生前整理・遺品買取</span>
      </div>
    </a>
    <div class="hidden md:block text-white/70 text-xs">受付 9:00–21:00（年中無休）</div>
    <div class="flex items-center gap-2">
      <a href="tel:052-990-3968" class="flex items-center gap-1.5 bg-orange hover:bg-orange-light text-white font-bold text-xs px-4 py-2 rounded-lg transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="hidden sm:inline">052-990-3968</span>
      </a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-line hover:opacity-90 text-white font-bold text-xs px-4 py-2 rounded-lg transition-opacity">LINE査定</a>
    </div>
  </div>
</header>

<main class="pt-14">

<!-- ═══ HERO: ティール背景+左テキスト+右BA写真 ═══ -->
<section class="bg-gradient-to-br from-teal-dark via-teal to-teal-light text-white py-14 md:py-24">
  <div class="max-w-6xl mx-auto px-5">
    <div class="md:flex md:items-center md:gap-10">
      <div class="md:flex-1 mb-10 md:mb-0">
        <div class="flex gap-2 mb-5">
          <span class="bg-orange text-white text-xs font-bold px-3 py-1 rounded-full">買取強化中</span>
          <span class="bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full">名古屋エリア</span>
        </div>
        <h1 class="text-2xl md:text-4xl font-black leading-tight mb-5">
          生前整理・遺品の買取は<br /><span class="text-orange-light">徳丸商会</span>にお任せ
        </h1>
        <p class="text-white/70 text-sm leading-relaxed mb-6">
          処分する前に、まず「買取査定」を。骨董品・貴金属・着物から家電まで、経験豊富なスタッフがご自宅で丁寧に査定します。
        </p>

        <!-- 3つの強み -->
        <div class="flex gap-3 mb-6">
          {[
            { icon: "¥0", label: "出張費・査定費" },
            { icon: "30分", label: "最短訪問" },
            { icon: "現金", label: "その場払い" },
          ].map(b => (
            <div class="bg-white/10 rounded-lg px-4 py-3 text-center flex-1">
              <p class="text-orange-light font-black text-lg leading-none">{b.icon}</p>
              <p class="text-white/60 text-[10px] mt-1">{b.label}</p>
            </div>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-3 mb-3">
          <a href="tel:052-990-3968" class="bg-orange hover:bg-orange-light text-white font-bold text-sm px-6 py-3.5 rounded-lg text-center transition-colors shadow-lg">
            今すぐ電話 052-990-3968
          </a>
          <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-line hover:opacity-90 text-white font-bold text-sm px-6 py-3.5 rounded-lg text-center transition-opacity shadow-lg">
            LINEで写真査定
          </a>
        </div>
        <p class="text-white/40 text-[10px]">査定のみOK / しつこい営業なし / キャンセル無料</p>
      </div>

      <!-- 右: ビフォーアフター -->
      <div class="md:w-[380px] flex-shrink-0">
        <div class="bg-bg-white rounded-xl overflow-hidden shadow-2xl">
          <div class="grid grid-cols-2">
            <div>
              <p class="bg-text text-white text-xs font-bold text-center py-1.5">Before</p>
              <img src={before} alt="回収前" class="w-full aspect-[4/3] object-cover" loading="eager" />
            </div>
            <div>
              <p class="bg-orange text-white text-xs font-bold text-center py-1.5">After</p>
              <img src={after} alt="回収後" class="w-full aspect-[4/3] object-cover" loading="eager" />
            </div>
          </div>
          <div class="p-3 bg-bg-gray text-center">
            <p class="text-teal font-bold text-xs">不用品をまるっと回収 → スッキリ</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 信頼バー ═══ -->
<section class="bg-bg-white border-b border-border py-6">
  <div class="max-w-4xl mx-auto px-5 flex flex-wrap justify-center gap-6 md:gap-12 text-center">
    {[
      { n: "1,200件+", l: "累計買取実績" },
      { n: "満足度98%", l: "自社調べ" },
      { n: "古物商許可取得", l: "第541042309800号" },
    ].map(b => (
      <div>
        <p class="text-teal font-black text-base md:text-lg">{b.n}</p>
        <p class="text-text-lighter text-[10px]">{b.l}</p>
      </div>
    ))}
  </div>
</section>

<!-- ═══ お悩み ═══ -->
<section class="py-14 md:py-20 bg-bg">
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-teal-dark mb-2">
      生前整理・遺品の処分に<br class="md:hidden" />お悩みではありませんか？
    </h2>
    <p class="text-text-light text-sm text-center mb-8">一つでも当てはまったら、まず無料査定を</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {[
        "遺品が大量にあり何から手をつけていいかわからない",
        "骨董品や貴金属の価値がわからず処分できない",
        "遺品整理業者の費用が高くて困っている",
        "故人の家が遠方で立ち会えない",
        "形見分けの後、残ったものの処分に困っている",
        "生前のうちに持ち物を整理しておきたい",
      ].map(p => (
        <div class="flex items-start gap-3 bg-bg-white rounded-lg p-4 border border-border shadow-sm">
          <span class="bg-orange text-white w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">✓</span>
          <p class="text-text text-sm leading-relaxed">{p}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ 遺品整理との違い ═══ -->
<section class="py-14 md:py-20 bg-bg-white">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-teal-dark mb-3">
      品物を処分する前に<br class="md:hidden" />徳丸商会の出張買取で査定しませんか？
    </h2>
    <p class="text-text-light text-sm mb-10 max-w-2xl mx-auto">
      遺品整理業者は片付け・処分がメインのサービスです。先に買取査定を行うことで、価値あるお品物を現金に換え、整理費用を大幅に抑えられます。
    </p>
    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm border-collapse max-w-2xl mx-auto">
        <thead>
          <tr>
            <th class="bg-text text-white px-4 py-3 text-left rounded-tl-lg w-24"></th>
            <th class="bg-text-light text-white px-4 py-3 text-center">遺品整理業者</th>
            <th class="bg-teal text-white px-4 py-3 text-center rounded-tr-lg">徳丸商会の買取</th>
          </tr>
        </thead>
        <tbody>
          {[
            ["費用", "数万〜数十万円", "無料（現金を受取）"],
            ["内容", "片付け・処分", "査定して現金買取"],
            ["お品物", "まとめて処分", "価値を見極め買取"],
            ["おすすめ順", "2番目に依頼", "最初に依頼 ★"],
          ].map(([l, a, b], i) => (
            <tr class={i % 2 === 0 ? "bg-bg" : "bg-bg-white"}>
              <td class="px-4 py-3 font-bold text-text border-r border-border">{l}</td>
              <td class="px-4 py-3 text-center text-text-light border-r border-border">{a}</td>
              <td class="px-4 py-3 text-center text-teal font-bold">{b}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="bg-teal-bg border border-teal/20 rounded-lg p-4 max-w-2xl mx-auto">
      <p class="text-teal-dark text-sm font-bold text-center">
        → まず徳丸商会で買取 → その後に整理業者へ = 最もお得な順序
      </p>
    </div>
  </div>
</section>

<!-- ═══ CTA帯 ═══ -->
<section class="py-8 bg-orange text-white text-center">
  <div class="max-w-3xl mx-auto px-5">
    <p class="font-bold text-base mb-3">処分する前に、まず無料査定</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="tel:052-990-3968" class="bg-white text-orange font-bold text-sm px-6 py-3 rounded-lg shadow hover:opacity-90 transition-opacity">052-990-3968</a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-line text-white font-bold text-sm px-6 py-3 rounded-lg shadow hover:opacity-90 transition-opacity">LINEで査定</a>
    </div>
  </div>
</section>

<!-- ═══ 買取品目 ═══ -->
<section id="items" class="py-14 md:py-20 bg-bg">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-teal-dark mb-3">様々な遺品・お品物を買い取ります</h2>
    <p class="text-text-light text-sm mb-8 max-w-lg mx-auto">「こんなものでも売れるの？」——実は値段がつくものは多いです</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
      {buyItems.map(item => (
        <div class="bg-bg-white rounded-lg p-3 border border-border text-sm text-text font-medium text-center shadow-sm">{item}</div>
      ))}
    </div>
    <div class="mt-6 bg-orange/5 border border-orange/20 rounded-lg p-4 max-w-2xl mx-auto">
      <p class="text-text text-sm">
        <strong class="text-orange">状態が悪くても大丈夫：</strong>シミのある着物、箱なしの食器、動かない時計など、まずはご相談ください。
      </p>
    </div>
  </div>
</section>

<!-- ═══ 選ばれる理由 ═══ -->
<section class="py-14 md:py-20 bg-bg-white">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-teal-dark mb-10">徳丸商会が選ばれる理由</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {[
        { n: "01", t: "幅広い品目を一括査定", d: "骨董品から家電まで、ジャンルを問わずまとめて査定。複数業者を呼ぶ手間なし。" },
        { n: "02", t: "遺品に配慮した丁寧な対応", d: "故人の大切なお品物を、一つひとつ丁寧に査定いたします。" },
        { n: "03", t: "出張費・査定費 完全無料", d: "費用は一切かかりません。査定だけ・相談だけでもお気軽に。" },
        { n: "04", t: "買取額で整理費用を軽減", d: "思わぬお品物に値段がつき、遺品整理費用をまかなえたケースも多数。" },
      ].map(r => (
        <div class="flex gap-4 bg-bg rounded-lg p-5 border border-border shadow-sm">
          <div class="w-12 h-12 bg-teal rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-white font-black text-sm">{r.n}</span>
          </div>
          <div>
            <p class="text-teal-dark font-bold text-sm mb-1">{r.t}</p>
            <p class="text-text-light text-sm leading-relaxed">{r.d}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ 流れ ═══ -->
<section class="py-14 md:py-20 bg-teal-dark text-white">
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center mb-10">出張買取の流れ</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { n: "01", t: "お電話・LINEで相談", d: "お品物の内容と訪問日時をお伝えください。写真での事前査定も可能。" },
        { n: "02", t: "訪問・査定・現金払い", d: "スタッフがお伺いし丁寧に査定。その場で現金をお渡しします。" },
        { n: "03", t: "搬出・お片付け完了", d: "買取品はそのまま搬出。重い物もスタッフにお任せ。" },
      ].map(s => (
        <div class="bg-white/10 rounded-xl p-6 text-center">
          <div class="w-14 h-14 bg-orange rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-white font-black text-lg">{s.n}</span>
          </div>
          <h3 class="text-white font-bold text-sm mb-2">{s.t}</h3>
          <p class="text-white/60 text-sm leading-relaxed">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ お客様の声 ═══ -->
<section class="py-14 md:py-20 bg-bg">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-teal-dark mb-10">お客様の声</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {voices.map(v => (
        <div class="bg-bg-white rounded-xl p-5 border border-border shadow-sm">
          <div class="flex gap-0.5 mb-3">{Array.from({length:5}).map(() => <span class="text-orange text-sm">★</span>)}</div>
          <p class="text-text text-sm leading-relaxed mb-3">{v.text}</p>
          <p class="text-text-lighter text-xs">{v.who}</p>
        </div>
      ))}
    </div>
    <p class="text-text-lighter text-xs mt-6">お客様満足度 <strong class="text-text">98%</strong>（自社調べ）</p>
  </div>
</section>

<!-- ═══ 対応エリア ═══ -->
<section id="area" class="py-14 md:py-20 bg-bg-white">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-teal-dark mb-10">出張買取対応エリア</h2>
    <div class="md:flex md:gap-12">
      <div class="mb-6 md:mb-0">
        <h3 class="text-teal font-bold text-sm mb-3">名古屋市（16区）</h3>
        <div class="flex flex-wrap gap-x-3 gap-y-1 text-text-light text-sm">{areas.map(w => <span>{w}</span>)}</div>
      </div>
      <div>
        <h3 class="text-teal font-bold text-sm mb-3">近郊エリア</h3>
        <div class="flex flex-wrap gap-x-3 gap-y-1 text-text-light text-sm">{nearby.map(a => <span>{a}</span>)}</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ FAQ ═══ -->
<section id="faq" class="py-14 md:py-20 bg-bg">
  <div class="max-w-3xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black text-center text-teal-dark mb-10">生前整理・遺品買取のよくあるご質問</h2>
    <div class="space-y-3">
      {faqItems.map(faq => (
        <div x-data="{ open: false }" class="bg-bg-white rounded-xl border border-border shadow-sm overflow-hidden">
          <button x-on:click="open = !open" class="w-full flex items-start justify-between gap-4 p-5 text-left" x-bind:aria-expanded="open.toString()">
            <div class="flex items-start gap-3">
              <span class="bg-teal text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">Q</span>
              <span class="text-text font-bold text-sm leading-relaxed">{faq.q}</span>
            </div>
            <span class="text-teal text-lg flex-shrink-0 transition-transform duration-200" x-bind:class="open && 'rotate-45'">+</span>
          </button>
          <div x-show="open" x-transition class="px-5 pb-5" style="display: none;">
            <div class="flex items-start gap-3 pl-0 md:pl-9">
              <span class="bg-orange text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">A</span>
              <p class="text-text-light text-sm leading-relaxed">{faq.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ 最終CTA ═══ -->
<section id="contact" class="py-16 md:py-24 bg-teal-dark text-white text-center">
  <div class="max-w-2xl mx-auto px-5">
    <h2 class="text-lg md:text-2xl font-black mb-3">処分する前に、まずはお電話を。</h2>
    <p class="text-white/60 text-sm mb-8">「こんなものでも売れるの？」というご質問だけでも大歓迎です。</p>
    <div class="flex flex-wrap justify-center gap-3 mb-4">
      <a href="tel:052-990-3968" class="bg-orange hover:bg-orange-light text-white font-bold text-base px-8 py-4 rounded-lg shadow-lg transition-colors">052-990-3968</a>
