---
import Layout from "../layouts/Layout.astro";
import { assetPath, basePath, homePath, sectionPath, privacyPolicyPath } from "../lib/site";
import { faqs } from "../data/faq";
import { areas as areaDataset } from "../data/areas";

const areaSlugByShortName = new Map(areaDataset.map((a) => [a.shortName, a.slug]));
const areaUrl = (shortName: string): string | null => {
  const slug = areaSlugByShortName.get(shortName);
  return slug ? `${basePath}area/${slug}/` : null;
};

const logo     = assetPath("logo.svg");
const hero     = assetPath("images/estate/hero.webp");
const hero800  = assetPath("images/estate/hero-800.webp");
const hero480  = assetPath("images/estate/hero-480.webp");
const bgWorry  = assetPath("images/estate/bg-worry.webp");
const staffTeam = assetPath("images/estate/staff-team.webp");
const bgArea   = assetPath("images/estate/bg-area.webp");
const cashPayment = assetPath("images/estate/cash-payment.webp");
const before   = assetPath("images/estate/before.webp");
const after    = assetPath("images/estate/after.webp");
const before2  = assetPath("images/estate/before2.webp");
const after2   = assetPath("images/estate/after2.webp");

const serviceSorting = assetPath("images/estate/service-sorting.webp");
const serviceKuyo    = assetPath("images/estate/service-kuyo.webp");
const serviceCarry   = assetPath("images/estate/service-carry.webp");
const staffPortrait  = assetPath("images/estate/staff-portrait.webp");

const items = [
  { name: "時計", img: assetPath("images/estate/item-watch.webp") },
  { name: "ダイヤ", img: assetPath("images/estate/item-diamond.webp") },
  { name: "宝石", img: assetPath("images/estate/item-gemstone.webp") },
  { name: "金・プラチナ", img: assetPath("images/estate/item-gold-platinum.webp") },
  { name: "ブランド品", img: assetPath("images/estate/item-brand-bag.webp") },
  { name: "服・毛皮", img: assetPath("images/estate/item-fur.webp") },
  { name: "骨董品", img: assetPath("images/estate/item-antique.webp") },
  { name: "装飾品", img: assetPath("images/estate/item-accessory.webp") },
  { name: "カメラ", img: assetPath("images/estate/item-camera.webp") },
  { name: "楽器", img: assetPath("images/estate/item-instrument.webp") },
  { name: "お酒", img: assetPath("images/estate/item-alcohol.webp") },
  { name: "古銭・硬貨", img: assetPath("images/estate/item-coins.webp") },
  { name: "着物", img: assetPath("images/estate/item-kimono.webp") },
  { name: "切手", img: assetPath("images/estate/item-stamps.webp") },
  { name: "金券", img: assetPath("images/estate/item-giftcard.webp") },
  { name: "茶道具", img: assetPath("images/estate/item-tea.webp") },
  { name: "掛軸・絵画", img: assetPath("images/estate/item-scroll.webp") },
  { name: "仏具", img: assetPath("images/estate/item-buddhist.webp") },
];

const results = [
  { name: "エメラルドの指輪 Pt900", price: "364,000", area: "愛知県名古屋市中区", desc: "エメラルド0.80ct、ダイヤモンド取り巻き、Pt900 10.4g。故人様の遺品整理にてお買取り。鑑別書付きで高額査定に。", img: assetPath("images/estate/result-emerald-ring.webp") },
  { name: "オパールの指輪 Pt900", price: "124,000", area: "愛知県名古屋市千種区", desc: "ウォーターオパール、ダイヤ0.83ct、Pt900 11.95g。生前整理のご依頼でお買取り。遊色効果が美しい逸品。", img: assetPath("images/estate/result-opal-ring.webp") },
  { name: "イエローダイヤモンドの指輪 K18", price: "94,000", area: "愛知県名古屋市緑区", desc: "イエローダイヤモンド、K18 15.0g。遺品整理にてお買取り。ファンシーカラーで希少価値あり。", img: assetPath("images/estate/result-yellow-diamond.webp") },
  { name: "金のネックレス K18", price: "200,000", area: "愛知県あま市", desc: "K18喜平チェーンネックレス。生前整理にてお買取り。金相場高騰中のタイミングで高額査定を実現。", img: assetPath("images/estate/result-gold-necklace.webp") },
  { name: "掛軸 江戸期 山水画", price: "180,000", area: "愛知県名古屋市東区", desc: "江戸時代後期の山水画掛軸。遺品整理にてお買取り。保存状態良好、落款・箱書き付きで骨董価値を評価。", img: assetPath("images/estate/result-antique-scroll.webp") },
  { name: "伊万里焼 大皿 明治期", price: "156,000", area: "愛知県清須市", desc: "明治期の伊万里焼染付大皿。生前整理にてお買取り。直径42cm、金彩残り良好。蔵から出てきた逸品を専門査定。", img: assetPath("images/estate/result-imari.webp") },
];


const voices = [
  { text: "母の遺品整理をお願いしました。思い出の品を丁寧に仕分けてくださり、価値のある着物は買い取っていただけました。費用も想定より安く済みました。", who: "名古屋市千種区 K.M様" },
  { text: "遠方に住んでいるため立ち会えませんでしたが、写真付きの報告で安心できました。仏壇の供養まで手配していただき感謝しています。", who: "東京都 T.S様" },
  { text: "父の遺品の中にあった掛軸と茶道具に思いがけない値がつき、整理費用をほぼ相殺できました。専門の査定員さんの知識に驚きました。", who: "名古屋市緑区 Y.N様" },
];

const areas = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const owariAreas = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","稲沢市","一宮市","江南市","犬山市","岩倉市","小牧市","春日井市","瀬戸市","尾張旭市","長久手市","日進市","東郷町","豊山町","大口町","扶桑町","大治町","蟹江町","飛島村"];
const chitaAreas = ["東海市","大府市","知多市","半田市","常滑市","東浦町","阿久比町","美浜町","武豊町","南知多町"];
const mikawaAreas = ["豊明市","刈谷市","知立市","安城市","岡崎市","豊田市","西尾市","碧南市","高浜市","みよし市","幸田町","豊川市","豊橋市","蒲郡市","新城市","田原市"];
const otherAreas = ["四日市市（三重県）","桑名市（三重県）"];
---

<Layout
  title="名古屋の遺品整理・生前整理・実家の片付け｜徳丸商会｜骨董買取で費用軽減"
  description="親が亡くなった後の遺品整理・実家の片付け・生前整理は名古屋の徳丸商会へ。骨董品・着物・貴金属・掛軸・茶道具など価値ある品をその場で現金買取し、整理費用を軽減。仕分け・搬出・供養まで一括対応。出張費・査定費0円、立会い不要OK、即日対応可。古物商許可業者・愛知県全域出張。052-990-3968"
  extraJsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "徳丸商会トップ", "item": "https://tokumaru-shokai.com/" },
        { "@type": "ListItem", "position": 2, "name": "遺品整理・生前整理", "item": "https://tokumaru-shokai.com/estate/" }
      ]
    }
  ]}
>

<!-- ══════════════════════════════════════════
  1. HEADER
══════════════════════════════════════════ -->
<header class="fixed top-0 inset-x-0 z-50 shadow-lg">
  <!-- 上部帯(PCのみ) -->
  <div class="hidden md:flex bg-teal-dark text-white text-xs py-1 px-5 justify-end items-center gap-6">
    <span class="whitespace-nowrap">受付 9:00〜21:00 年中無休</span>
    <span class="whitespace-nowrap">古物商許可 第541042309800号</span>
  </div>
  <!-- メインヘッダー -->
  <div class="bg-white/95 backdrop-blur-md border-b border-teal/10">
    <div class="max-w-6xl mx-auto px-4 h-[60px] md:h-[72px] flex items-center justify-between">
      <a href={homePath} class="flex items-center gap-2.5 shrink-0">
        <img src={logo} alt="徳丸商会ロゴ" width="48" height="48" class="w-11 h-11 md:w-14 md:h-14" loading="eager" />
        <div>
          <div class="text-teal-dark font-black text-base md:text-xl leading-tight whitespace-nowrap">徳丸商会</div>
          <div class="text-text-lighter text-[9px] md:text-xs font-bold leading-tight whitespace-nowrap">遺品整理・生前整理専門</div>
        </div>
      </a>
      <nav class="hidden md:flex items-center gap-1">
        {[
          { label: "サービス", id: "service" },
          { label: "買取品目", id: "items" },
          { label: "流れ", id: "flow" },
          { label: "FAQ", id: "faq" },
        ].map(item => (
          <a href={sectionPath(item.id)} class="text-text-light hover:text-teal hover:bg-teal/5 text-sm font-bold px-4 py-2 rounded-lg transition-all whitespace-nowrap">{item.label}</a>
        ))}
      </nav>
      <div class="flex items-center gap-2 shrink-0">
        <a href="tel:052-990-3968" class="flex items-center justify-center gap-1.5 bg-orange hover:bg-orange-light text-white font-bold text-[11px] md:text-sm px-3 md:px-4 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-colors whitespace-nowrap shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          電話
        </a>
        <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-1.5 bg-line hover:brightness-110 text-white font-bold text-[11px] md:text-sm px-3 md:px-4 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          LINE
        </a>
      </div>
    </div>
  </div>
</header>

<main class="pt-[60px] md:pt-[calc(1.75rem+4.5rem)]">

<!-- ══════════════════════════════════════════
  2. HERO
══════════════════════════════════════════ -->
<section class="bg-teal-dark text-white">
  <!-- PC版: 左テキスト + 右に大きな人物写真 -->
  <div class="hidden md:block relative overflow-hidden">
    <img src={hero} srcset={`${hero480} 480w, ${hero800} 800w, ${hero} 1400w`} sizes="100vw" alt="名古屋の遺品整理・生前整理スタッフ" class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" width="1400" height="768" />
    <div class="absolute inset-0 bg-gradient-to-l from-teal-dark via-teal-dark/80 via-50% to-teal-dark/10"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-teal-dark/50 to-transparent"></div>
    <div class="relative max-w-6xl mx-auto px-5 py-24 flex justify-end">
      <div class="max-w-xl">
        <div class="flex flex-wrap gap-2 mb-5">
          {["出張費0円","明朗会計","立会い不要OK","即日対応"].map(b => (
            <span class="bg-orange text-white text-xs font-black px-3 py-1.5 rounded-full whitespace-nowrap shadow">{b}</span>
          ))}
        </div>
        <h1 class="text-4xl lg:text-5xl font-black leading-[1.15] mb-5" style="text-shadow: 0 2px 12px rgba(0,0,0,0.5)">
          名古屋の<span class="text-orange-light">遺品整理・<br />生前整理</span>なら<br />徳丸商会
        </h1>
        <p class="text-white/80 text-base mb-8 max-w-lg" style="text-shadow: 0 1px 6px rgba(0,0,0,0.4)">
          遺品整理・生前整理・福祉施設入居前の片付けまで対応。故人の大切なお品物を丁寧に仕分け・査定し、価値ある品はその場で現金買取いたします。
        </p>
        <div class="flex flex-row gap-3 mb-4">
          <a href="tel:052-990-3968" class="cta-glow bg-orange hover:bg-orange-light text-white font-black text-lg px-8 py-4 rounded-xl text-center transition-colors shadow-xl whitespace-nowrap"><span class="text-[10px] hidden md:block mb-0.5 opacity-80">今日中に来てほしい方</span>電話で無料相談</a>
          <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="cta-glow-line bg-line hover:brightness-110 text-white font-bold text-lg px-8 py-4 rounded-xl text-center transition-all shadow-xl whitespace-nowrap">LINEで無料査定</a>
        </div>
        <p class="text-white/60 text-xs">受付 9:00〜21:00 年中無休 ／ 出張費・査定費0円</p>
      </div>
    </div>
  </div>

  <!-- モバイル版: 画像を上部に見せてからテキスト -->
  <div class="md:hidden bg-teal-dark text-white">
    <!-- 画像 + 吹き出し -->
    <div class="relative">
      <img src={hero480} srcset={`${hero480} 480w, ${hero800} 800w`} sizes="100vw" alt="名古屋の遺品整理・生前整理スタッフ" class="w-full aspect-[16/9] object-cover object-[35%_30%]" loading="eager" fetchpriority="high" width="480" height="263" />
      <div class="absolute inset-0 bg-gradient-to-t from-teal-dark via-transparent to-transparent"></div>
    </div>

    <!-- テキスト: 画像の下 -->
    <div class="px-5 -mt-8 relative pb-6">
      <div class="flex flex-wrap gap-1.5 mb-3">
        {["出張費0円","明朗会計","立会い不要","即日対応"].map(b => (
          <span class="bg-orange text-white text-[10px] font-black px-2.5 py-1 rounded-full whitespace-nowrap shadow">{b}</span>
        ))}
      </div>

      <p class="text-[1.7rem] font-black leading-[1.15] mb-2" role="heading" aria-level="1">
        名古屋の<span class="text-orange-light">遺品整理・<br />生前整理</span>なら徳丸商会
      </p>

      <p class="text-white/70 text-[12px] leading-relaxed mb-5">
        遺品整理・生前整理・福祉施設入居前の片付けまで対応。<br />価値ある品はその場で現金買取いたします。
      </p>

      <div class="flex gap-2.5 mb-2">
        <a href="tel:052-990-3968" class="cta-glow flex-1 bg-orange text-white font-black text-xs py-3.5 rounded-xl text-center shadow-lg whitespace-nowrap">電話で相談</a>
        <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="cta-glow-line flex-1 bg-line text-white font-bold text-xs py-3.5 rounded-xl text-center shadow-lg whitespace-nowrap">LINE査定</a>
      </div>
      <p class="text-white/60 text-[9px] text-center">受付 9:00〜21:00 年中無休 / 出張費・査定費0円</p>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
  3. 信頼バー（数値で揃えた事実訴求）
══════════════════════════════════════════ -->
<section class="border-t-4 border-orange bg-white shadow-md">
  <div class="max-w-5xl mx-auto px-5 py-5 md:py-7">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-5 md:gap-0 md:divide-x md:divide-border stagger-children">
      <div class="reveal text-center px-2 md:px-4">
        <div class="flex items-baseline justify-center gap-0.5 mb-1">
          <span class="text-teal-dark font-black text-3xl md:text-4xl leading-none">49</span>
          <span class="text-teal-dark font-black text-base md:text-lg">エリア</span>
        </div>
        <p class="text-orange font-bold text-[11px] md:text-sm whitespace-nowrap">出張対応</p>
        <p class="text-text-lighter text-[9px] md:text-[10px] mt-0.5 whitespace-nowrap">名古屋＋愛知＋三重北部</p>
      </div>
      <div class="reveal text-center px-2 md:px-4">
        <div class="flex items-baseline justify-center gap-0.5 mb-1">
          <span class="text-teal-dark font-black text-3xl md:text-4xl leading-none">18</span>
          <span class="text-teal-dark font-black text-base md:text-lg">品目</span>
        </div>
        <p class="text-orange font-bold text-[11px] md:text-sm whitespace-nowrap">専門査定対応</p>
        <p class="text-text-lighter text-[9px] md:text-[10px] mt-0.5 whitespace-nowrap">骨董・貴金属・着物まで</p>
      </div>
      <div class="reveal text-center px-2 md:px-4">
        <div class="flex items-baseline justify-center gap-0.5 mb-1">
          <span class="text-teal-dark font-black text-3xl md:text-4xl leading-none">0</span>
          <span class="text-teal-dark font-black text-base md:text-lg">円</span>
        </div>
        <p class="text-orange font-bold text-[11px] md:text-sm whitespace-nowrap">出張費・査定費</p>
        <p class="text-text-lighter text-[9px] md:text-[10px] mt-0.5 whitespace-nowrap">完全無料・追加料金なし</p>
      </div>
      <div class="reveal text-center px-2 md:px-4">
        <div class="flex items-baseline justify-center gap-0.5 mb-1">
          <span class="text-teal-dark font-black text-3xl md:text-4xl leading-none">365</span>
          <span class="text-teal-dark font-black text-base md:text-lg">日</span>
        </div>
        <p class="text-orange font-bold text-[11px] md:text-sm whitespace-nowrap">年中無休対応</p>
        <p class="text-text-lighter text-[9px] md:text-[10px] mt-0.5 whitespace-nowrap">9:00〜21:00</p>
      </div>
    </div>
    <p class="text-text-lighter text-[9px] md:text-[10px] text-center mt-4 md:mt-5 leading-relaxed">
      古物商許可 第541042309800号（名古屋市公安委員会届出）
    </p>
  </div>
</section>

<!-- ══════════════════════════════════════════
  3.5 キャンペーン枠（期間限定割引）
══════════════════════════════════════════ -->
<section id="campaign" class="py-10 md:py-14 bg-gradient-to-br from-orange/10 via-orange/5 to-transparent">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-7 md:mb-9 reveal">
      <span class="inline-block bg-orange text-white text-[10px] md:text-xs font-black px-3 py-1.5 rounded-full mb-3 tracking-wider">CAMPAIGN</span>
      <h2 class="text-xl md:text-3xl font-black text-teal-dark leading-tight">
        ご家族の負担を、<span class="text-orange">少しでも軽くしたい。</span>
      </h2>
      <p class="text-text-light text-xs md:text-sm mt-2">徳丸商会では、下記の割引キャンペーンを実施しています</p>
    </div>

