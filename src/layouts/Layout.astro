---
interface Props {
  title: string;
  description: string;
  extraJsonLd?: Record<string, unknown>[];
}

import "../styles/global.css";
import { assetPath, homePath } from "../lib/site";
import { faqsToJsonLd } from "../data/faq";

const { title, description, extraJsonLd = [] } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL(homePath, siteUrl).toString();
const ogImage = new URL(assetPath("og-image.webp"), siteUrl).toString();
const faviconUrl = assetPath("favicon.svg");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="keywords" content="遺品整理,名古屋,生前整理,遺品買取,骨董品買取,着物買取,貴金属買取,遺品整理業者,福祉施設入居,仏壇処分" />
    <meta name="theme-color" content="#1d7078" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://googleads.g.doubleclick.net https://www.google.com https://www.google-analytics.com https://www.googleadservices.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://www.google.com https://googleads.g.doubleclick.net https://www.googleadservices.com https://www.google-analytics.com https://www.google.co.jp; connect-src 'self' https://www.google-analytics.com https://www.google.com https://googleads.g.doubleclick.net https://analytics.google.com https://fonts.googleapis.com https://fonts.gstatic.com https://region1.google-analytics.com; frame-src https://www.googletagmanager.com https://googleads.g.doubleclick.net" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="徳丸商会の遺品整理・生前整理。名古屋の骨董品・着物・貴金属を出張買取。" />
    <meta property="og:site_name" content="徳丸商会｜名古屋の遺品整理・生前整理" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="徳丸商会の遺品整理・生前整理。名古屋の骨董品・着物・貴金属を出張買取。" />

    <!-- LCP Hero画像のプリロード -->
    <link rel="preload" as="image" type="image/webp" href={assetPath("images/estate/hero.webp")} fetchpriority="high" />

    <!-- Fonts: JS非同期読み込み（レンダリングブロック完全回避） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      (function(){var l=document.createElement('link');l.rel='stylesheet';l.href='https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&family=Shippori+Mincho:wght@400;700&display=swap';document.head.appendChild(l);})();
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-W493L98W');
    </script>

    <!-- JSON-LD: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${homeUrl}#localbusiness`,
      "name": "徳丸商会",
      "description": "名古屋市・近郊エリアの出張買取サービス。家電・家具・ブランド品をその場で現金買取。出張費・査定費0円。",
      "telephone": "052-990-3968",
      "url": homeUrl,
      "image": ogImage,
      "priceRange": "$$",
      "openingHours": "Mo-Su 09:00-21:00",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "名古屋市",
        "addressRegion": "愛知県",
        "addressCountry": "JP"
      },
      "areaServed": [
        { "@type": "City", "name": "名古屋市", "containedInPlace": { "@type": "State", "name": "愛知県" } },
        { "@type": "City", "name": "あま市" },
        { "@type": "City", "name": "清須市" },
        { "@type": "City", "name": "北名古屋市" },
        { "@type": "City", "name": "津島市" },
        { "@type": "City", "name": "愛西市" },
        { "@type": "City", "name": "弥富市" },
        { "@type": "City", "name": "東海市" },
        { "@type": "City", "name": "大府市" },
        { "@type": "City", "name": "刈谷市" },
        { "@type": "City", "name": "豊明市" },
        { "@type": "City", "name": "四日市市", "containedInPlace": { "@type": "State", "name": "三重県" } }
      ],
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "35.1709",
        "longitude": "136.8815"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "387",
        "bestRating": "5"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "telephone": "052-990-3968",
        "availableLanguage": ["ja"],
        "areaServed": "JP"
      },
      "sameAs": ["https://lin.ee/j4wK9IM"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "出張買取サービス",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "遺品整理" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "生前整理" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "福祉施設入居前の片付け" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "骨董品・貴金属・着物の買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "仏壇・位牌の供養・処分" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "家電・家具の出張買取" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "不用品回収・搬出" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "形見分けの相談・支援" } }
        ]
      }
    })} />

    <!-- JSON-LD: FAQPage (src/data/faq.ts から自動生成) -->
    <script type="application/ld+json" set:html={JSON.stringify(faqsToJsonLd())} />

    <!-- JSON-LD: HowTo (AEO対策 - AI検索エンジンが手順を引用しやすくする) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "名古屋で遺品整理・生前整理を依頼する方法",
      "description": "徳丸商会の遺品整理サービスを利用する手順です。お電話またはLINEでのお問い合わせから、訪問・仕分け・査定・買取・搬出までワンストップで完了します。",
      "totalTime": "PT1H",
      "estimatedCost": {
        "@type": "MonetaryAmount",
        "currency": "JPY",
        "value": "0"
      },
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "お電話・LINEでご相談",
          "text": "遺品整理・生前整理のご希望内容や訪問日時をお伝えください。LINEなら写真を送るだけで事前相談も可能です。052-990-3968まで。"
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "訪問・仕分け・査定・現金買取",
          "text": "スタッフがご自宅にお伺いし、遺品を丁寧に仕分け。価値ある品は専門査定員がその場で査定し、現金をお渡しします。立会い不要での作業も可能です。"
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "搬出・回収・供養",
          "text": "不用品の搬出・回収を一括で対応。仏壇・位牌などは提携寺院で供養いたします。お部屋の養生も丁寧に行います。"
        }
      ]
    })} />

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "徳丸商会",
      "url": homeUrl,
      "logo": new URL(assetPath("logo.svg"), siteUrl).toString(),
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "052-990-3968",
        "contactType": "customer support",
        "availableLanguage": "ja",
        "areaServed": "JP"
      }
    })} />

    {extraJsonLd.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body class="antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W493L98W"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <slot />

    <!-- Alpine.js -->
    <script>
      import Alpine from "alpinejs";
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
