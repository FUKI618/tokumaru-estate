---
interface Props {
  title: string;
  description: string;
  extraJsonLd?: Record<string, unknown>[];
}

import "../styles/global.css";
import { assetPath, homePath } from "../lib/site";
import { faqsToJsonLd } from "../data/faq";

const { title, description, extraJsonLd = [] } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL(homePath, siteUrl).toString();
const ogImage = new URL(assetPath("og-image.webp"), siteUrl).toString();
const faviconUrl = assetPath("favicon.svg");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="keywords" content="遺品整理,名古屋,生前整理,遺品買取,骨董品買取,着物買取,貴金属買取,遺品整理業者,福祉施設入居,仏壇処分" />
    <meta name="theme-color" content="#1d7078" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://googleads.g.doubleclick.net https://www.google.com https://www.google-analytics.com https://www.googleadservices.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://www.google.com https://googleads.g.doubleclick.net https://www.googleadservices.com https://www.google-analytics.com https://www.google.co.jp; connect-src 'self' https://www.google-analytics.com https://www.google.com https://googleads.g.doubleclick.net https://analytics.google.com https://fonts.googleapis.com https://fonts.gstatic.com https://region1.google-analytics.com; frame-src https://www.googletagmanager.com https://googleads.g.doubleclick.net" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="徳丸商会の遺品整理・生前整理。名古屋の骨董品・着物・貴金属を出張買取。" />
    <meta property="og:site_name" content="徳丸商会｜名古屋の遺品整理・生前整理" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="徳丸商会の遺品整理・生前整理。名古屋の骨董品・着物・貴金属を出張買取。" />

    <!-- LCP Hero画像のプリロード -->
    <link rel="preload" as="image" type="image/webp" href={assetPath("images/estate/hero.webp")} fetchpriority="high" />

    <!-- Fonts (ハイブリッド戦略):
         - 本文 = システムフォント（ネットワーク負荷0KB、OS最適化）
         - 見出し = Noto Sans JP 700のみ + display:optional で遅延・非ブロッキング
         font-display:optional により、フォントが100ms以内に取得できない場合
         fallback固定（FOUC回避）。subset chunksは表示文字種に応じて取得 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      (function(){
        // 見出し用：Noto Sans JP 700のみ・display:optional・遅延読み込み
        // requestIdleCallback で TTI 後に取得開始（FCP/LCPに影響させない）
        var loadHeadingFont = function(){
          var l = document.createElement('link');
          l.rel = 'stylesheet';
          l.href = 'https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@700&display=optional';
          document.head.appendChild(l);
        };
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadHeadingFont, { timeout: 2000 });
        } else {
          setTimeout(loadHeadingFont, 1500);
        }
      })();
    </script>

    <!-- Google Tag Manager: 3秒遅延で読み込み（FCP/LCP改善） -->
    <script is:inline>
      window.dataLayer=window.dataLayer||[];
      setTimeout(function(){
        (function(w,d,s,l,i){w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
        var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
        j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
        f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-W493L98W');
      },3000);
    </script>

